# ── Mobile app environment ───────────────────────────────────────────────
# Copy this file to `.env` (gitignored) and adjust for your machine.
#
# API base URL the app talks to. MUST include the trailing /api prefix.
# Match the port to the backend's PORT (apps/backend/.env → currently 3009).
#
# Host depends on where the app runs:
#   Android emulator : http://10.0.2.2:3009/api   (10.0.2.2 = host loopback)
#   iOS simulator    : http://localhost:3009/api
#   Physical device  : http://<your-computer-LAN-IP>:3009/api
EXPO_PUBLIC_API_URL=http://10.0.2.2:3009/api
