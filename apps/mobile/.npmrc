; Expo's config-plugin resolver uses Node's flat require.resolve(), which
; can't traverse pnpm's symlinked store layout. Force npm-style flat
; node_modules so EAS Build cloud (and local prebuild) can find plugin
; packages like expo-secure-store / expo-apple-authentication.
node-linker=hoisted
shamefully-hoist=true
public-hoist-pattern[]=*
