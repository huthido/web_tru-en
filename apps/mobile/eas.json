{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.yeuyeu.net/api",
        "EXPO_PUBLIC_ADMOB_ANDROID_APP_ID": "ca-app-pub-1865587135077064~2953143576"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.yeuyeu.net/api",
        "EXPO_PUBLIC_ADMOB_ANDROID_APP_ID": "ca-app-pub-1865587135077064~2953143576"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

