generator client {
  provider = "prisma-client-js"
}

// Seed configuration
// Run with: npm run prisma:seed

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL bypasses PgBouncer for `prisma migrate deploy` (transaction
  // pooling doesn't support all DDL). Optional — if unset, prisma falls
  // back to DATABASE_URL, which is fine when not using PgBouncer.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String? // Nullable cho OAuth users
  avatar        String?
  displayName   String?
  bio           String?   @db.Text
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  /// Soft-delete timestamp. Khi user tự xoá tài khoản trong app (Apple
  /// §5.1.1(v)): PII bị nullify, email/username đổi thành placeholder
  /// unique theo id, isActive = false, deletedAt = now(). NULL = tài khoản
  /// hoạt động bình thường.
  deletedAt     DateTime?
  refreshToken  String? // Optional: cho refresh token strategy
  // OAuth fields
  provider      String? // 'local', 'google', 'facebook'
  providerId    String? // OAuth provider user ID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  uploadedChapters        Chapter[]                @relation("ChapterUploader")
  comments                Comment[]
  favorites               Favorite[]
  follows                 Follow[]
  ratings                 Rating[]
  readingHistory          ReadingHistory[]
  authoredStories         Story[]                  @relation("StoryAuthor")
  viewLogs                ViewLog[]
  approvalRequests        ApprovalRequest[]        @relation("ApprovalRequests")
  reviewedApprovals       ApprovalRequest[]        @relation("ReviewedApprovals")
  createdAds              Ad[]                     @relation("AdCreator")
  createdCampaigns        Campaign[]               @relation("CampaignCreator")
  adImpressions           AdImpression[]           @relation("AdImpressionUser")
  adClicks                AdClick[]                @relation("AdClickUser")
  oauthCodes              OAuthCode[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  createdNotifications    Notification[]           @relation("NotificationCreator")
  pushTokens              UserPushToken[]
  wallet                  UserWallet?
  chapterPurchases        ChapterPurchase[]
  storyPurchases          StoryPurchase[]
  sentDonations           AuthorDonation[]         @relation("DonationSender")
  receivedDonations       AuthorDonation[]         @relation("DonationReceiver")
  uploadedImages          UserImage[]
  payments                Payment[]
  withdrawalRequests      WithdrawalRequest[]      @relation("WithdrawalRequester")
  processedWithdrawals    WithdrawalRequest[]      @relation("WithdrawalProcessor")
  // Apple §1.2 — UGC report + block.
  ugcReportsFiled         UgcReport[]              @relation("UgcReportReporter")
  ugcReportsReviewed      UgcReport[]              @relation("UgcReportResolver")
  blocks                  UserBlock[]              @relation("UserBlockBlocker")
  blockedBy               UserBlock[]              @relation("UserBlockBlocked")
  // Art feed (mục Nghệ thuật / Khám phá).
  artPosts                ArtPost[]
  artLikes                ArtLike[]
  artComments             ArtComment[]
  artStories              ArtStory[]
  artStoryViews           ArtStoryView[]
  // Báo bug từ người dùng (web + mobile).
  bugReports              BugReport[]              @relation("BugReporter")
  // Theo dõi tác giả (khác với Follow theo truyện). Phục vụ điều kiện
  // bật kiếm tiền (≥100 followers) + nút "Theo dõi tác giả" ở profile MXH.
  authorFollowsFollowing  AuthorFollow[]           @relation("AuthorFollowFollower")
  authorFollowers         AuthorFollow[]           @relation("AuthorFollowTarget")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([isActive])
  @@index([provider, providerId]) // Composite index cho OAuth lookup
  @@map("users")
}

model Story {
  id               String            @id @default(cuid())
  title            String
  slug             String            @unique
  description      String?
  coverImage       String?
  authorId         String
  authorName       String?
  status           StoryStatus       @default(DRAFT)
  accessType       StoryAccessType   @default(FREE) // Spec mục 4
  price            Int               @default(0) // Coin price for VIP whole-story unlock (accessType=VIP)
  isPublished      Boolean           @default(false)
  viewCount        Int               @default(0)
  likeCount        Int               @default(0)
  followCount      Int               @default(0)
  rating           Float             @default(0)
  ratingCount      Int               @default(0)
  isRecommended    Boolean           @default(false)
  /// Tác giả opt-in nhận xu từ quảng cáo hiển thị trong truyện này.
  /// Mặc định off — phải đủ điều kiện monetization mới bật được (xem
  /// MonetizationService.assertEligibleForAdvancedFeatures).
  adRevenueEnabled Boolean           @default(false)
  country          String?
  tags             String[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastChapterAt    DateTime?
  chapters         Chapter[]
  comments         Comment[]
  favorites        Favorite[]
  follows          Follow[]
  ratings          Rating[]
  author           User              @relation("StoryAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  storyCategories  StoryCategory[]
  storyTags        StoryTag[]
  viewLogs         ViewLog[]
  approvalRequests ApprovalRequest[] @relation("StoryApprovals")
  readingHistory   ReadingHistory[]
  storyPurchases   StoryPurchase[]

  @@index([slug])
  @@index([authorId])
  @@index([status])
  @@index([isPublished])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([lastChapterAt])
  @@index([country])
  @@index([rating])
  @@index([viewCount])
  @@index([followCount])
  @@index([isPublished, status, createdAt]) // Composite for homepage queries
  @@index([isPublished, rating, ratingCount]) // Composite for top rated
  @@index([isPublished, likeCount, followCount]) // Composite for most liked
  @@index([isRecommended, isPublished, createdAt]) // Composite for recommended
  @@map("stories")
}

model Chapter {
  id             String           @id @default(cuid())
  storyId        String
  title          String
  slug           String
  content        String
  images         String[]
  order          Int
  isPublished    Boolean          @default(false)
  /// Lịch tự xuất bản: khi != null và đã tới giờ, cron ChaptersCron sẽ tự
  /// set isPublished=true (chỉ với truyện đã publish). null = không đặt lịch.
  scheduledPublishAt DateTime?
  viewCount      Int              @default(0)
  wordCount      Int              @default(0)
  readingTime    Int              @default(0)
  uploaderId     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  story          Story            @relation(fields: [storyId], references: [id], onDelete: Cascade)
  uploader       User?            @relation("ChapterUploader", fields: [uploaderId], references: [id])
  comments       Comment[]
  readingHistory ReadingHistory[]
  viewLogs       ViewLog[]

  approvalRequests ApprovalRequest[] @relation("ChapterApprovals")
  price            Int               @default(0) // Coin price to unlock
  purchases        ChapterPurchase[]

  @@unique([storyId, slug])
  @@index([storyId])
  @@index([storyId, order])
  @@index([slug])
  @@index([isPublished])
  @@index([createdAt])
  // Cron quét chương tới hạn đăng: lọc isPublished=false + scheduledPublishAt<=now.
  @@index([isPublished, scheduledPublishAt])
  @@map("chapters")
}

model Comment {
  id        String    @id @default(cuid())
  userId    String
  storyId   String?
  chapterId String?
  content   String
  parentId  String?
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chapter   Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  story     Story?    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([storyId])
  @@index([chapterId])
  @@index([parentId])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([storyId, isDeleted, createdAt]) // Composite index for story comments query
  @@index([chapterId, isDeleted, createdAt]) // Composite index for chapter comments query
  @@index([parentId, createdAt]) // Composite index for nested replies
  @@map("comments")
}

model Follow {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([createdAt])
  @@map("follows")
}

/// Theo dõi tác giả (user-to-user). Khác với Follow ở trên — Follow theo
/// dõi *truyện*. AuthorFollow theo dõi *user (tác giả)*. Phục vụ:
///   1. Điều kiện bật kiếm tiền (≥100 followers).
///   2. Nút "Theo dõi tác giả" trên trang cá nhân /u/[username].
/// onDelete: Cascade — nếu user (follower hoặc author) bị xoá, follow biến mất.
model AuthorFollow {
  id        String   @id @default(cuid())
  userId    String // người follow
  authorId  String // tác giả được follow
  createdAt DateTime @default(now())

  user   User @relation("AuthorFollowFollower", fields: [userId], references: [id], onDelete: Cascade)
  author User @relation("AuthorFollowTarget", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([userId, authorId])
  @@index([authorId])
  @@index([userId])
  @@index([createdAt])
  @@map("author_follows")
}

model Category {
  id              String          @id @default(cuid())
  name            String          @unique
  slug            String          @unique
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  storyCategories StoryCategory[]

  @@index([slug])
  @@map("categories")
}

model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String
  chapterId String // Current chapter being read
  storyId   String // Story this history belongs to (required)
  progress  Int      @default(0) // Progress of current chapter (0-100)
  lastRead  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId]) // One history entry per user per story
  @@index([userId])
  @@index([userId, lastRead])
  @@index([storyId])
  @@index([chapterId])
  @@map("reading_history")
}

model ViewLog {
  id        String   @id @default(cuid())
  storyId   String?
  chapterId String?
  userId    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([storyId])
  @@index([chapterId])
  @@index([userId])
  @@index([createdAt])
  @@index([ipAddress])
  @@map("view_logs")
}

model StoryCategory {
  id         String   @id @default(cuid())
  storyId    String
  categoryId String
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  story      Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, categoryId])
  @@index([storyId])
  @@index([categoryId])
  @@map("story_categories")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([createdAt])
  @@map("favorites")
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([rating])
  @@index([createdAt])
  @@map("ratings")
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  storyTags StoryTag[]

  @@index([slug])
  @@map("tags")
}

model StoryTag {
  id        String   @id @default(cuid())
  storyId   String
  tagId     String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([storyId, tagId])
  @@index([storyId])
  @@index([tagId])
  @@map("story_tags")
}

model Banner {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  String
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
  @@index([position])
  @@index([order])
  @@map("banners")
}

model ContentReport {
  id          String       @id @default(cuid())
  userId      String?
  storyId     String?
  chapterId   String?
  reportType  String
  description String?
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([storyId])
  @@index([chapterId])
  @@index([createdAt])
  @@map("content_reports")
}

model ApprovalRequest {
  id         String         @id @default(cuid())
  userId     String
  storyId    String?
  chapterId  String?
  type       ApprovalType
  status     ApprovalStatus @default(PENDING)
  message    String?        @db.Text
  adminNote  String?        @db.Text
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation("ApprovalRequests", fields: [userId], references: [id], onDelete: Cascade)
  story      Story?         @relation("StoryApprovals", fields: [storyId], references: [id], onDelete: Cascade)
  chapter    Chapter?       @relation("ChapterApprovals", fields: [chapterId], references: [id], onDelete: Cascade)
  reviewer   User?          @relation("ReviewedApprovals", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([storyId])
  @@index([chapterId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("approval_requests")
}

enum UserRole {
  USER
  AUTHOR
  ADMIN
}

enum StoryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  ONGOING
  COMPLETED
}

// Spec mục 4 — loại truyện do tác giả tự chọn ("tuỳ chọn kích hoạt"):
//  FREE     : ai cũng đọc, bỏ qua mọi giá.
//  FREEMIUM : mua từng chương trả phí (Chapter.price); KHÔNG hiển thị nhãn trả
//             phí ở danh sách (theo spec).
//  VIP      : khóa toàn truyện, mua một lần (Story.price) mở hết chương.
enum StoryAccessType {
  FREE
  FREEMIUM
  VIP
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  REJECTED
}

enum ApprovalType {
  STORY_PUBLISH
  CHAPTER_PUBLISH
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  // System broadcast (admin-created)
  SYSTEM_UPDATE // Cập nhật hệ thống
  MAINTENANCE // Bảo trì
  NEW_FEATURE // Tính năng mới
  ANNOUNCEMENT // Thông báo chung
  WARNING // Cảnh báo
  INFO // Thông tin

  // Auto-generated user events
  STORY_APPROVED // Truyện được duyệt
  STORY_REJECTED // Truyện bị từ chối
  STORY_NEW_CHAPTER // Truyện theo dõi có chương mới
  DONATION_RECEIVED // Nhận ủng hộ
  CHAPTER_PURCHASED // Có người mua chương
  STORY_PURCHASED // Có người mua truyện VIP
  WITHDRAWAL_PROCESSED // Yêu cầu rút xu được xử lý
  COIN_TRANSFER_RECEIVED // Nhận chuyển khoản xu
  COIN_DEPOSITED // Nạp xu thành công
  COMMENT_REPLY // Có người trả lời bình luận
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  budget      Float?
  spent       Float    @default(0)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ads         Ad[]
  createdBy   User?    @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([createdById])
  @@map("campaigns")
}

model Ad {
  id             String         @id @default(cuid())
  title          String?
  description    String?        @db.Text
  // imageUrl required ở DB-level (default '') để zero-downtime; nhưng ở DTO chỉ
  // bắt buộc khi sourceType = SELF_SERVED. 3rd-party (AdSense/AdMob/FAN/Custom)
  // có thể bỏ trống — slot ID nằm trong networkConfig.
  imageUrl       String         @default("")
  linkUrl        String?
  type           AdType         @default(BANNER)
  position       AdPosition     @default(BOTTOM)
  // Nguồn ad — quyết định cách render ở client (image vs 3rd-party SDK/script).
  sourceType     AdSourceType   @default(SELF_SERVED)
  // Config riêng cho mỗi sourceType:
  // - GOOGLE_ADSENSE: { adUnitId: string, format?: 'auto'|'rectangle'|'horizontal', responsive?: boolean }
  // - GOOGLE_ADMOB:   { adUnitId: string, format?: 'banner'|'interstitial'|'native' }
  // - FAN:            { placementId: string }
  // - CUSTOM_SCRIPT:  { html: string }
  // - SELF_SERVED:    null
  networkConfig  Json?
  // Platform target (chỉ áp dụng cho 3rd-party): 'web' | 'mobile' | 'all'.
  // SELF_SERVED hiện thị mọi nơi (kept null).
  platform       String?
  isActive       Boolean        @default(true)
  startDate      DateTime?
  endDate        DateTime?
  clickCount     Int            @default(0)
  viewCount      Int            @default(0)
  impressions    Int            @default(0) // Total impressions (show count)
  popupInterval  Int? // Number of chapters to read before showing popup (only for POPUP type)
  priority       Int            @default(0) // Higher priority = shown first
  campaignId     String?
  targetAudience Json? // Targeting rules: {categories: [], roles: [], devices: [], minChaptersRead: 0}
  // Cấu hình hiển thị runtime, override hardcode mặc định component:
  // { heights: {base, sm, md}, rotateInterval, maxStack, openInNewTab, customCss, format }
  displayConfig  Json?
  // Quy tắc chèn INLINE banner: { afterParagraph: 5, repeatEvery: 5, maxOccurrences: null }
  // Chỉ áp dụng khi ad bind vào slot có position=INLINE.
  inlineRule     Json?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  campaign       Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("AdCreator", fields: [createdById], references: [id], onDelete: SetNull)
  adImpressions  AdImpression[]
  adClicks       AdClick[]
  slotBindings   AdSlotBinding[]

  @@index([type])
  @@index([position])
  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([priority])
  @@index([campaignId])
  @@index([createdById])
  @@index([sourceType])
  @@index([platform])
  @@map("ads")
}

/// Slot registry — mỗi slot là một vị trí cụ thể trên 1 page route mà admin
/// có thể bật/tắt và bind ads vào. Khác với Ad.position (category chung),
/// slot có key duy nhất gắn cụ thể với pageKey + position.
model AdSlot {
  id        String          @id @default(cuid())
  /// Key duy nhất tham chiếu từ frontend, vd 'home.top', 'reading.inline'.
  key       String          @unique
  /// Route page chứa slot này: 'home' | 'stories.list' | 'stories.detail' |
  /// 'reading' | 'search' | 'profile' | 'library'.
  pageKey   String
  position  AdPosition
  /// Friendly label cho admin UI, vd 'Banner đầu trang chủ'.
  label     String
  /// Số ads tối đa hiển thị đồng thời trong slot (sidebar stack, banner rotate).
  maxAds    Int             @default(1)
  enabled   Boolean         @default(true)
  /// Filter type bắt buộc của ad bind vào slot. Null = chấp nhận mọi type.
  adType    AdType?
  /// Filter platform: 'web' | 'mobile' | 'all'. Null = all.
  platform  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  bindings  AdSlotBinding[]

  @@index([pageKey, enabled])
  @@index([key])
  @@map("ad_slots")
}

/// Bảng nối many-to-many giữa Ad và AdSlot — 1 ad có thể bind nhiều slot,
/// 1 slot có thể chứa nhiều ad (theo maxAds + priority).
model AdSlotBinding {
  id       String  @id @default(cuid())
  adId     String
  slotId   String
  /// Priority binding (cao hơn show trước trong slot này). Tách khỏi
  /// Ad.priority vì cùng 1 ad có thể có priority khác nhau ở từng slot.
  priority Int     @default(0)
  ad       Ad      @relation(fields: [adId], references: [id], onDelete: Cascade)
  slot     AdSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([adId, slotId])
  @@index([slotId])
  @@index([adId])
  @@map("ad_slot_bindings")
}

enum AdSourceType {
  SELF_SERVED // Image + linkUrl tự host (Cloudinary/Garage)
  GOOGLE_ADSENSE // Web — render <ins class="adsbygoogle">
  GOOGLE_ADMOB // Mobile — react-native-google-mobile-ads BannerAd
  FAN // Facebook Audience Network — mobile
  CUSTOM_SCRIPT // Admin paste HTML/<script> từ ad network khác (Adsterra, MGID…)
}

model AdImpression {
  id        String   @id @default(cuid())
  adId      String
  userId    String?
  ipAddress String?
  userAgent String?
  device    String? // 'mobile', 'tablet', 'desktop'
  location  String? // Country/Region
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User?    @relation("AdImpressionUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([adId])
  @@index([userId])
  @@index([createdAt])
  @@index([ipAddress])
  @@index([device])
  @@map("ad_impressions")
}

model AdClick {
  id        String   @id @default(cuid())
  adId      String
  userId    String?
  ipAddress String?
  userAgent String?
  device    String? // 'mobile', 'tablet', 'desktop'
  location  String? // Country/Region
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User?    @relation("AdClickUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([adId])
  @@index([userId])
  @@index([createdAt])
  @@index([ipAddress])
  @@index([device])
  @@map("ad_clicks")
}

enum AdType {
  POPUP
  BANNER
  SIDEBAR
}

enum AdPosition {
  TOP
  BOTTOM
  SIDEBAR_LEFT
  SIDEBAR_RIGHT
  INLINE
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g., 'lien-he-quang-cao', 'ung-ho', 'popup-support'
  title       String
  content     String   @db.Text // HTML content
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@map("pages")
}

model Settings {
  id                         String   @id @default(cuid())
  siteName                   String   @default("Web Truyện HungYeu")
  siteDescription            String?  @db.Text
  siteLogo                   String?
  siteFavicon                String?
  siteEmail                  String?
  sitePhone                  String?
  siteAddress                String?  @db.Text
  siteFacebook               String?
  siteTwitter                String?
  siteX                      String? // X (formerly Twitter)
  siteYoutube                String?
  siteInstagram              String?
  siteTikTok                 String?
  siteLinkedIn               String?
  siteThreads                String?
  maintenanceMode            Boolean  @default(false)
  maintenanceMessage         String?  @db.Text
  allowRegistration          Boolean  @default(true)
  requireEmailVerification   Boolean  @default(false)
  // Donation rev-share: % the platform keeps when a user donates coins to an
  // author. 0 = author keeps 100%. Capped at 50 in the DTO validator.
  donationPlatformFeePercent Int      @default(2)
  // Spec mục 17 — chapter / VIP story sale rev-share. Tracked separately from
  // donations so support can tune them independently (e.g. lower fee on sales
  // to encourage authors to set paid content). Backfilled = donation fee.
  chapterSaleFeePercent      Int      @default(2)
  // Spec mục 17 — số xu tối thiểu tác giả được phép yêu cầu rút.
  minWithdrawalCoins         Int      @default(1000)
  // Spec mục 2 — cho phép chuyển xu giữa user ("nếu cho phép"). Mặc định tắt.
  allowCoinTransfer          Boolean  @default(false)
  // Quảng cáo — global kill switch + cấu hình network ID. Client gọi
  // GET /ads/config để lấy snapshot dạng JSON.
  adsEnabled                 Boolean  @default(true)
  googleAdsensePublisherId   String? // ca-pub-XXXXXXXXXXXXXXXX
  admobAndroidAppId          String? // ca-app-pub-XXXX~YYYY (App ID, không phải unit ID)
  admobIosAppId              String?
  fanPlacementId             String? // Facebook Audience Network app ID
  adsTxtContent              String?  @db.Text // Plain text serve qua GET /ads.txt
  // GDPR consent banner — bật theo region nếu cần. Mặc định bật (an toàn).
  consentRequired            Boolean  @default(true)
  // Danh sách hostname được phép dùng ảnh ngoài (vd: "i.pinimg.com"). Admin quản lý qua UI.
  allowedImageDomains        String[] @default([])
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@map("settings")
}

model OAuthCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@index([expiresAt])
  @@map("oauth_codes")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String // Email or username or IP
  type       String // 'email', 'username', 'ip'
  successful Boolean  @default(false)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([identifier, createdAt])
  @@index([ipAddress, createdAt])
  @@index([createdAt])
  @@map("login_attempts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// System Notifications
model Notification {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text
  type        NotificationType
  priority    NotificationPriority @default(NORMAL)
  /// Deep-link URL khi user click vào notification (vd: /story/abc,
  /// /wallet/history). Null = generic broadcast, click chỉ mở list.
  actionUrl   String?              @db.VarChar(500)
  targetRole  UserRole? // null = all users, or specific role
  sendEmail   Boolean              @default(false) // Send via email
  isActive    Boolean              @default(true)
  createdById String? // null = system/auto notification (donate/sale/withdrawal)
  createdBy   User?                @relation("NotificationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Relations
  recipients NotificationRecipient[]

  @@index([type])
  @@index([targetRole])
  @@index([isActive])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, isRead])
  @@index([notificationId])
  @@map("notification_recipients")
}

/// Expo push token per device. Một user có thể có nhiều thiết bị (mobile,
/// tablet); mỗi thiết bị 1 row. Logout xoá token tương ứng; cron 90 ngày
/// inactive dọn token cũ.
model UserPushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique // ExponentPushToken[xxx] hoặc raw FCM token
  platform  String // 'ios' | 'android' | 'web'
  deviceId  String? // optional — để xoá khi user logout 1 thiết bị
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_push_tokens")
}

model UserWallet {
  id               String            @id @default(cuid())
  userId           String            @unique
  /// Bought via VNPay/Apple IAP/Google Play. Spendable on content/transfer.
  /// NOT withdrawable (Apple §3.1.1 / Google Play Billing §4.3).
  purchasedBalance Int               @default(0)
  /// Received from chapter/story sales, donations, withdrawal-reject refunds.
  /// Withdrawable as VND. NOT transferable (anti-laundering).
  earnedBalance    Int               @default(0)
  /// @deprecated denormalized total = purchasedBalance + earnedBalance.
  /// Kept during transition; will be dropped in a follow-up migration.
  balance          Int               @default(0)
  // Admin fraud control (spec mục 2). Locked = không thể chi tiêu/chuyển/rút.
  isLocked         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     CoinTransaction[]

  @@index([earnedBalance])
  @@map("user_wallets")
}

model CoinTransaction {
  id          String          @id @default(cuid())
  walletId    String
  amount      Int // Positive for deposit, negative for spend
  type        TransactionType
  description String
  referenceId String? // ID of the order or chapter
  createdAt   DateTime        @default(now())
  wallet      UserWallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("coin_transactions")
}

model CoinPackage {
  id              String    @id @default(cuid())
  name            String
  coinAmount      Int
  priceVND        Int
  description     String?
  isActive        Boolean   @default(true)
  // Store-specific product IDs so the mobile app can map a server package
  // to its IAP SKU on Apple App Store Connect / Google Play Console. Nullable
  // because not every package needs to be sold on mobile (web-only top-ups
  // via VNPay stay unset). When a package is sold via Apple/Google, pricing
  // is dictated by the store's price tier — not priceVND.
  appleProductId  String?   @unique
  googleProductId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]

  @@map("coin_packages")
}

model ChapterPurchase {
  id          String   @id @default(cuid())
  userId      String
  chapterId   String
  pricePaid   Int // Gross coins paid by the buyer (= platformFee + netAmount)
  platformFee Int      @default(0) // Coins kept by the platform (donationPlatformFeePercent of pricePaid, rounded up)
  netAmount   Int      @default(0) // Coins actually credited to the author (pricePaid - platformFee)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
  @@index([createdAt])
  @@map("chapter_purchases")
}

// VIP whole-story purchase (accessType=VIP). Mirrors ChapterPurchase: one
// row unlocks every chapter of the story for the buyer.
model StoryPurchase {
  id          String   @id @default(cuid())
  userId      String
  storyId     String
  pricePaid   Int // Gross coins paid by the buyer (= platformFee + netAmount)
  platformFee Int      @default(0) // Coins kept by the platform
  netAmount   Int      @default(0) // Coins credited to the author
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([createdAt])
  @@map("story_purchases")
}

enum TransactionType {
  DEPOSIT
  PURCHASE_CHAPTER
  PURCHASE_STORY
  ADMIN_ADJUST
  REFUND
  BONUS
  DONATE_AUTHOR
  WITHDRAWAL
  TRANSFER
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Spec mục 17 — yêu cầu rút xu của tác giả. Xu bị giữ (trừ khỏi ví) ngay khi
// tạo yêu cầu; admin duyệt (APPROVED = đã chuyển khoản) hoặc từ chối
// (REJECTED = hoàn xu lại ví). Thông tin ngân hàng chụp lại theo từng yêu cầu.
model WithdrawalRequest {
  id                String           @id @default(cuid())
  userId            String
  amount            Int // Coins requested (held from wallet at creation)
  status            WithdrawalStatus @default(PENDING)
  bankName          String
  bankAccountNumber String
  bankAccountName   String
  note              String?          @db.Text // admin note / rejection reason
  processedById     String?
  processedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation("WithdrawalRequester", fields: [userId], references: [id], onDelete: Cascade)
  processedBy       User?            @relation("WithdrawalProcessor", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawal_requests")
}

enum PaymentProvider {
  VNPAY
  MOMO
  ZALOPAY
  MANUAL
  APPLE_IAP // Apple In-App Purchase — credits purchasedBalance only
  GOOGLE_PLAY // Google Play Billing — credits purchasedBalance only
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

model Payment {
  id           String          @id @default(cuid())
  userId       String
  packageId    String? // optional — direct top-up if null
  provider     PaymentProvider
  amount       Int // VND
  coinAmount   Int // coins to be credited on success
  status       PaymentStatus   @default(PENDING)
  txnRef       String          @unique // Our internal reference sent to gateway
  providerTxn  String? // Gateway-side transaction id (e.g. VNPay TransactionNo)
  providerData Json? // Raw IPN payload for audit
  paidAt       DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  package CoinPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([createdAt])
  @@map("payments")
}

model AuthorDonation {
  id          String   @id @default(cuid())
  userId      String
  authorId    String
  storyId     String?
  amount      Int // Gross amount paid by sender (= platformFee + netAmount)
  platformFee Int      @default(0) // Coins kept by the platform (2% of amount, rounded up)
  netAmount   Int      @default(0) // Coins actually credited to the author (amount - platformFee)
  message     String?  @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation("DonationSender", fields: [userId], references: [id], onDelete: Cascade)
  author      User     @relation("DonationReceiver", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([authorId])
  @@index([storyId])
  @@index([createdAt])
  @@map("author_donations")
}

model UserImage {
  id        String   @id @default(cuid())
  userId    String
  url       String
  folder    String // 'chapter-images', 'story-covers', etc.
  filename  String
  size      Int // file size in bytes
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, folder])
  @@index([userId, createdAt])
  @@map("user_images")
}

// Apple §1.2 — cho phép user báo cáo UGC (truyện / chương / bình luận /
// user). Bảng MỚI dành riêng cho luồng báo cáo từ mobile/web; model
// ContentReport cũ vẫn giữ nguyên cho luồng admin web hiện hữu.
enum UgcReportTargetType {
  STORY
  CHAPTER
  COMMENT
  USER
}

enum UgcReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model UgcReport {
  id           String              @id @default(cuid())
  reporterId   String
  targetType   UgcReportTargetType
  targetId     String // id của truyện / chương / comment / user
  reason       String // SPAM | ABUSE | ILLEGAL | OTHER (mã ngắn)
  note         String?             @db.Text
  status       UgcReportStatus     @default(PENDING)
  createdAt    DateTime            @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  reporter     User                @relation("UgcReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy   User?               @relation("UgcReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([status])
  @@index([createdAt])
  @@map("ugc_reports")
}

// Apple §1.2 — cho phép user chặn user khác. Quan hệ một chiều: nếu A chặn B,
// thì nội dung B không hiện ra cho A; B vẫn xem được A. Dùng @@unique để
// tránh duplicate block.
model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

// ─── Art Feed (mục Nghệ thuật / Khám phá) ───────────────────────────────────

model ArtPost {
  id           String       @id @default(cuid())
  userId       String
  imageUrl     String
  caption      String?      @db.Text
  /// Dimensions gợi ý (px) — frontend dùng để tính masonry height trước khi ảnh tải.
  width        Int?
  height       Int?
  likeCount    Int          @default(0)
  commentCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes        ArtLike[]
  comments     ArtComment[]

  @@index([userId])
  @@index([createdAt])
  @@map("art_posts")
}

model ArtLike {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      ArtPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
  @@map("art_likes")
}

model ArtComment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      ArtPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("art_comments")
}

/// Stories 24h — ảnh tạm thời, hết hạn sau expiresAt.
model ArtStory {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  expiresAt DateTime
  viewCount Int      @default(0)
  createdAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  views     ArtStoryView[]

  @@index([userId])
  @@index([expiresAt])
  @@map("art_stories")
}

model ArtStoryView {
  userId    String
  storyId   String
  viewedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     ArtStory  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@map("art_story_views")
}

// ============ BUG REPORTS ============
// Người dùng báo lỗi từ web/mobile; AI agent đọc qua MCP server
// (tools/mcp-bug-reports) với API key — xem AGENT_API_KEY.

enum BugReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BugPlatform {
  WEB
  ANDROID
  IOS
  OTHER
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model BugReport {
  id          String          @id @default(cuid())
  title       String          @db.VarChar(200)
  description String          @db.Text
  platform    BugPlatform     @default(WEB)
  severity    BugSeverity     @default(MEDIUM)
  status      BugReportStatus @default(OPEN)
  /// URL trang web hoặc tên màn hình mobile nơi gặp lỗi.
  pageUrl     String?         @db.VarChar(500)
  /// userAgent (web) hoặc model máy + OS version (mobile).
  deviceInfo  String?         @db.VarChar(500)
  appVersion  String?         @db.VarChar(50)
  /// Ghi chú xử lý của admin hoặc AI agent.
  adminNote   String?         @db.Text
  reporterId  String?
  reporter    User?           @relation("BugReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([platform])
  @@index([createdAt])
  @@map("bug_reports")
}
