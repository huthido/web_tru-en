# ====== Backend env template — copy to apps/backend/.env for local dev ======
# In production (Coolify), set these in the application's Secrets/Environment UI.

# --- Runtime ---
NODE_ENV=production
PORT=3009

# Comma-separated list of allowed origins (no wildcard in prod).
# Add every domain that serves the frontend, including www and staging.
CORS_ORIGIN=https://example.com,https://www.example.com
FRONTEND_URL=https://example.com

# --- Database (Postgres) ---
# When using the bundled compose Postgres, the hostname is `postgres`.
DATABASE_URL=postgresql://user:password@postgres:5432/web_truyen_db?schema=public

# --- Redis (BullMQ queue). When unset, email send falls back to synchronous. ---
REDIS_URL=redis://redis:6379

# --- Meilisearch (full-text search). When unset, /search falls back to Postgres LIKE. ---
# MEILI_MASTER_KEY: dùng chung giữa backend và container meilisearch — cùng giá trị.
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=

# --- Auth secrets (CHANGE THESE — 32+ random characters each) ---
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# --- Cloudinary (recommended in prod — local /uploads is volatile across replicas) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Garage (S3-compatible) — highest priority if all four are set ---
S3_ENDPOINT=
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=web-truyen
S3_PUBLIC_BASE_URL=

# --- OAuth providers (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Donation rev-share ---
# Fallback value used only if the Settings row is missing/unreadable.
# Admin can edit this live via /admin/settings without redeploy.
DONATION_PLATFORM_FEE_PERCENT=2

# --- VNPay payment gateway ---
# Register at https://sandbox.vnpayment.vn/ to get TMN_CODE + HASH_SECRET.
# In production use https://pay.vnpay.vn/vpcpay.html as VNPAY_PAY_URL.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://api.example.com/api/payments/vnpay/return
VNPAY_IPN_URL=https://api.example.com/api/payments/vnpay/ipn
