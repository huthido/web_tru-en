# ====== Frontend env template — copy to apps/frontend/.env for local dev ======
# IMPORTANT: NEXT_PUBLIC_* values are baked into the client bundle at BUILD time.
# In Coolify, supply them as build args (not just runtime env) so the bundle
# references the correct production URLs.

NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_APP_URL=https://example.com
