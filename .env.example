# ====== Root env template for docker-compose / Coolify ======
# Copy to .env at the repo root, then `docker compose up -d`.
# Coolify users: paste these into the Compose application's "Environment" tab.

# --- Redis (queue + cache) ---
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# --- Meilisearch (full-text search) ---
# MEILI_HOST = how the backend reaches Meili (inside compose: http://meilisearch:7700).
# MEILI_MASTER_KEY: ≥32-char random string (openssl rand -hex 32). Used both as Meili's
# master key and as the backend's API key for now.
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=changeMePleaseInProduction32chars
MEILI_ENV=production
MEILI_PORT=7700

# --- Postgres (bundled service) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=web_truyen_db
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=3009
# DATABASE_URL → PgBouncer (connection pooler) cho Prisma Client lúc runtime.
# DIRECT_URL → Postgres trực tiếp cho `prisma migrate` (DDL không qua pooler).
# Password phải khớp POSTGRES_PASSWORD ở trên.
DATABASE_URL=postgresql://user:change-me-strong-password@pgbouncer:5432/web_truyen_db?schema=public&pgbouncer=true&connection_limit=20
DIRECT_URL=postgresql://user:change-me-strong-password@postgres:5432/web_truyen_db?schema=public
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
CORS_ORIGIN=https://example.com,https://www.example.com
FRONTEND_URL=https://example.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Garage (S3-compatible self-hosted storage) ---
# Priority order: Garage > Cloudinary > local /uploads.
# To enable Garage, set ALL FOUR of S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY, S3_PUBLIC_BASE_URL.
# Inside docker-compose, S3_ENDPOINT is http://garage:3900 (service name).
# S3_PUBLIC_BASE_URL is the URL clients hit to read files — point this at a reverse
# proxy that serves bucket "web-truyen" publicly (or at port 3902 web endpoint).
S3_ENDPOINT=
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=web-truyen
S3_PUBLIC_BASE_URL=

# Garage secrets — override placeholder baked trong garage.toml.
# Sinh mỗi giá trị bằng `openssl rand -hex 32`. Bỏ trống = dùng placeholder.
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=

# Optional host port mappings for the bundled Garage container
GARAGE_S3_PORT=3900
GARAGE_WEB_PORT=3902
GARAGE_ADMIN_PORT=3903

# --- OAuth (Google / Facebook) ---
# CALLBACK_URL phải tuyệt đối và khớp CHÍNH XÁC "Authorized redirect URI"
# khai báo trong Google Cloud Console / Facebook App settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://api.example.com/api/auth/facebook/callback

# --- Donation rev-share (fallback only; live value comes from Settings table) ---
DONATION_PLATFORM_FEE_PERCENT=2

# --- VNPay ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://api.example.com/api/payments/vnpay/return
VNPAY_IPN_URL=https://api.example.com/api/payments/vnpay/ipn

# --- Frontend (build-time + runtime) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_APP_URL=https://example.com
