# =====================================================================
# web_truyen — MẪU ENV (template). Đây là file DUY NHẤT cần đọc để biết
# toàn bộ biến môi trường của dự án. File này ĐƯỢC commit.
# =====================================================================
#
# Dự án dùng 3 file .env (tất cả gitignored — KHÔNG commit):
#
#   1) .env  (thư mục gốc)        -> NGUỒN CHÍNH. Docker compose đọc file
#      này; backend native fallback về đây cho secrets/keys dùng chung.
#      Host = TÊN SERVICE compose (pgbouncer, redis, meilisearch...).
#
#   2) apps/backend/.env          -> Override cho backend chạy NATIVE.
#      Chỉ chứa biến đổi host sang localhost (DATABASE_URL, DIRECT_URL,
#      REDIS_URL, MEILI_HOST) + PORT. @nestjs/config nạp file này TRƯỚC
#      root .env nên nó thắng.
#
#   3) apps/frontend/.env         -> Frontend chạy NATIVE. Chỉ NEXT_PUBLIC_*.
#
# Khởi tạo nhanh:
#   cp .env.example .env                  (rồi điền giá trị thật)
#   # tạo apps/backend/.env + apps/frontend/.env theo 2 mục cuối file này
#
# Hai cách chạy ở máy local:
#   A) NATIVE (hot-reload, khuyến nghị khi code):
#        docker compose up -d postgres redis meilisearch
#        pnpm dev
#   B) FULL STACK TRONG DOCKER (giống production):
#        pnpm docker:local            # build + up -d
#        pnpm docker:local:down       # dừng
#      -> mở http://localhost:3000 (đổi FRONTEND_PORT bên dưới nếu bận).
#
# Coolify: dán phần "[1] ROOT .env" vào tab Environment của app Compose.
# =====================================================================


# =====================================================================
# [1] ROOT .env  — Docker compose + nguồn chung cho backend native
# =====================================================================

# --- Postgres (service bundled) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=web_truyen_db
POSTGRES_PORT=5432

# --- Database URL (host = tên service compose) ---
# DATABASE_URL -> PgBouncer (pooler) cho Prisma Client lúc runtime.
# DIRECT_URL   -> Postgres trực tiếp cho `prisma migrate` (DDL không qua pooler).
# Password phải khớp POSTGRES_PASSWORD ở trên.
DATABASE_URL=postgresql://user:change-me-strong-password@pgbouncer:5432/web_truyen_db?schema=public&pgbouncer=true&connection_limit=20
DIRECT_URL=postgresql://user:change-me-strong-password@postgres:5432/web_truyen_db?schema=public

# --- Redis (queue + cache) ---
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# --- Bảo mật — chuỗi ngẫu nhiên >= 32 ký tự (openssl rand -hex 32) ---
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# --- CORS / Frontend URL ---
CORS_ORIGIN=https://example.com,https://www.example.com
FRONTEND_URL=https://example.com

# --- Frontend build-time (ngữ cảnh Docker) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_APP_URL=https://example.com
INTERNAL_API_URL=http://backend:3009

# --- Meilisearch (full-text search) ---
# MEILI_MASTER_KEY: chuỗi >= 32 ký tự (openssl rand -hex 32).
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=changeMePleaseInProduction32chars
MEILI_ENV=production
MEILI_PORT=7700

# --- Backend port (compose) ---
BACKEND_PORT=3009

# --- Email / SMTP (rỗng = không gửi mail, chỉ log link ra console) ---
# Gmail: tạo App Password tại https://myaccount.google.com/apppasswords
# EMAIL_FROM nên trùng EMAIL_USER khi dùng Gmail.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# --- Cloudinary (tùy chọn — lưu ảnh) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Garage (S3 self-hosted) ---
# Thứ tự ưu tiên lưu ảnh: Garage > Cloudinary > local /uploads.
# Bật Garage = set ĐỦ 4 biến: S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY,
# S3_PUBLIC_BASE_URL. Trong compose S3_ENDPOINT = http://garage:3900.
S3_ENDPOINT=
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=web-truyen
S3_PUBLIC_BASE_URL=
# Secret cho container garage — sinh mỗi giá trị: openssl rand -hex 32.
# Rỗng = garage giữ placeholder trong garage.toml -> container crash.
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=
GARAGE_S3_PORT=3900
GARAGE_WEB_PORT=3902
GARAGE_ADMIN_PORT=3903

# --- OAuth (Google / Facebook) ---
# CALLBACK_URL phải tuyệt đối và khớp CHÍNH XÁC "Authorized redirect URI".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://api.example.com/api/auth/facebook/callback

# --- VNPay ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://api.example.com/api/payments/vnpay/return
VNPAY_IPN_URL=https://api.example.com/api/payments/vnpay/ipn

# --- Chia sẻ doanh thu donate (fallback; giá trị thật ở bảng Settings) ---
DONATION_PLATFORM_FEE_PERCENT=2


# =====================================================================
# [2] apps/backend/.env  — chỉ override cho backend chạy NATIVE
# =====================================================================
# Tạo file apps/backend/.env với đúng các biến dưới (phần còn lại lấy
# từ root .env). Postgres/Redis chạy trong Docker, publish ra host theo
# docker-compose.override.yml (Postgres 5433, Redis 6379).
#
#   PORT=3009
#   DATABASE_URL="postgresql://user:password@localhost:5433/web_truyen_db?schema=public"
#   DIRECT_URL="postgresql://user:password@localhost:5433/web_truyen_db?schema=public"
#   REDIS_URL="redis://localhost:6379"
#   MEILI_HOST=            # rỗng -> full-text search fallback Postgres LIKE


# =====================================================================
# [3] apps/frontend/.env  — frontend chạy NATIVE
# =====================================================================
# Tạo file apps/frontend/.env với:
#
#   NEXT_PUBLIC_API_URL=http://localhost:3009
#   NEXT_PUBLIC_APP_URL=http://localhost:3002
